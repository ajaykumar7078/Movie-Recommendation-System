   "source": [
    "# 🍿 Movie Recommendation System
",
    "## Exploratory Data Analysis & Model Building
",
    "
",
    "**Author:** Ajay Chaudhary
",
    "
",
    "This notebook walks through the full process: data loading, EDA, building a content-based recommendation engine using TF-IDF + Cosine Similarity, and evaluating performance."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd
",
    "import numpy as np
",
    "import matplotlib.pyplot as plt
",
    "import seaborn as sns
",
    "import sys, os
",
    "
",
    "# Add project to path
",
    "sys.path.insert(0, os.path.abspath('..'))
",
    "
",
    "from src.data_loader import MovieDataLoader
",
    "from src.recommender import MovieRecommender
",
    "
",
    "# Plot settings
",
    "plt.style.use('ggplot')
",
    "sns.set_palette('Set2')
",
    "%matplotlib inline
",
    "
",
    "print('Setup complete!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load & Explore Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data
",
    "loader = MovieDataLoader(data_dir='../data')
",
    "movies, ratings = loader.load()
",
    "
",
    "print(f'Movies: {movies.shape}')
",
    "print(f'Ratings: {ratings.shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "movies.head(10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "ratings.head(10)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Data Distribution & Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Genre distribution
",
    "genre_counts = {}
",
    "for glist in movies['genres'].str.split('|'):
",
    "    for g in glist:
",
    "        genre_counts[g] = genre_counts.get(g, 0) + 1
",
    "
",
    "genre_df = pd.DataFrame(sorted(genre_counts.items(), key=lambda x: x[1], reverse=True),
",
    "                       columns=['Genre', 'Count'])
",
    "
",
    "plt.figure(figsize=(12, 6))
",
    "sns.barplot(data=genre_df, x='Count', y='Genre', palette='viridis')
",
    "plt.title('Genre Distribution in Dataset')
",
    "plt.tight_layout()
",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Rating distribution
",
    "plt.figure(figsize=(10, 5))
",
    "sns.histplot(ratings['rating'], bins=20, kde=True, color='purple')
",
    "plt.title('Rating Distribution')
",
    "plt.xlabel('Rating')
",
    "plt.ylabel('Count')
",
    "plt.show()
",
    "
",
    "print(f'Average rating: {ratings["rating"].mean():.2f}')
",
    "print(f'Median rating: {ratings["rating"].median():.2f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Movies per rating count
",
    "movie_rating_counts = ratings.groupby('movieId').size().reset_index(name='count')
",
    "plt.figure(figsize=(10, 5))
",
    "sns.histplot(movie_rating_counts['count'], bins=30, color='teal')
",
    "plt.title('Number of Ratings per Movie')
",
    "plt.xlabel('Rating Count')
",
    "plt.tight_layout()
",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Build Recommendation Engine"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize and build the recommender
",
    "recommender = MovieRecommender(data_dir='../data')
",
    "recommender.load_and_preprocess()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Get content-based recommendations
",
    "recs = recommender.content_based_recommendations('The Dark Knight (2008)', n=8)
",
    "recs_df = pd.DataFrame(recs)
",
    "recs_df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Genre-based recommendations
",
    "genre_recs = recommender.genre_based_recommendations('Sci-Fi', n=10)
",
    "pd.DataFrame(genre_recs)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Hybrid recommendations
",
    "hybrid = recommender.hybrid_recommendations(n=10)
",
    "pd.DataFrame(hybrid)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Evaluation
",
    "
",
    "Evaluate precision@k by checking if recommended movies share genres with the query movie."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def precision_at_k(query_movie, k=5):
",
    "    """Check precision: how many of top-k recs share genres with query."""
",
    "    query_genres = set(movies[movies['title'] == query_movie]['genres_list'].values[0])
",
    "    recs = recommender.content_based_recommendations(query_movie, n=k)
",
    "    
",
    "    if not recs or 'error' in recs[0]:
",
    "        return 0.0
",
    "    
",
    "    hits = 0
",
    "    rec_titles = [r['title'] for r in recs]
",
    "    
",
    "    for title in rec_titles:
",
    "        rec_genres = set(movies[movies['title'] == title]['genres_list'].values[0])
",
    "        if query_genres & rec_genres:  # At least one shared genre
",
    "            hits += 1
",
    "    
",
    "    return hits / k
",
    "
",
    "# Test on a few movies
",
    "test_movies = ['The Dark Knight (2008)', 'Inception (2010)', 'Toy Story (1995)', 
",
    "               'Pulp Fiction (1994)', 'Interstellar (2014)']
",
    "
",
    "results = []
",
    "for m in test_movies:
",
    "    p5 = precision_at_k(m, 5)
",
    "    p10 = precision_at_k(m, 10)
",
    "    results.append({'Movie': m, 'Precision@5': f'{p5:.0%}', 'Precision@10': f'{p10:.0%}'})
",
    "
",
    "eval_df = pd.DataFrame(results)
",
    "eval_df"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Save Model Artifacts
",
    "
",
    "The recommender loads data on-demand from CSV files, so no serialization is needed. For production, you could pickle the similarity matrix for faster startup."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save the TF-IDF matrix and movie list for production use
",
    "import joblib
",
    "
",
    "model_dir = '../model_cache'
",
    "os.makedirs(model_dir, exist_ok=True)
",
    "
",
    "joblib.dump(recommender.cosine_sim, f'{model_dir}/cosine_sim.pkl')
",
    "joblib.dump(recommender.indices, f'{model_dir}/indices.pkl')
",
    "print('Model artifacts saved!')"
   ]
  },
